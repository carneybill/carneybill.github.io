{{- $pages := slice -}}
{{- range where site.RegularPages "Params.search_exclude" "ne" true -}}
  {{- $summary := .Params.excerpt | default .Summary | default .Description | plainify | htmlUnescape | replaceRE `[\r\n\t]+` " " -}}
  {{- $content := .Plain | htmlUnescape | replaceRE `[\r\n\t]+` " " -}}
  {{- $section := .Section | default "page" | humanize -}}
  {{- $tags := "" -}}
  {{- with .Params.tags }}{{ $tags = delimit . " " }}{{ end -}}
  {{- $date := "" -}}
  {{- if not .PublishDate.IsZero -}}
    {{- $date = .PublishDate.Format "2006-01-02" -}}
  {{- else if not .Date.IsZero -}}
    {{- $date = .Date.Format "2006-01-02" -}}
  {{- end -}}
  {{- $pages = $pages | append (dict
    "title" .Title
    "summary" $summary
    "content" $content
    "permalink" .RelPermalink
    "section" $section
    "tags" $tags
    "date" $date
  ) -}}
{{- end -}}
{{- $pages | jsonify -}}
